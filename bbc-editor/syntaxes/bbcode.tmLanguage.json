{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "BBCode",
	"scopeName": "source.bbcode",
	"patterns": [{ "include": "#keywords" }],
	"repository": {
		"keywords": {
			"patterns": [
				{
					"name": "entity.name.tag",
					"match": "\\[[^\\]]+\\]"
				},
				{
					"name": "constant.numeric",
					"match": "\\d"
				}
			]
		}
	}
}
